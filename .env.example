# OpenPanel local env. Copy to .env before `docker compose up`.
# .env is git-ignored. Don't commit it.

# PostgreSQL
POSTGRES_USER=openpanel
POSTGRES_PASSWORD=openpanel_local
POSTGRES_DB=openpanel

# Hostname is the compose service name.
DATABASE_URL=postgresql://openpanel:openpanel_local@postgres:5432/openpanel
DATABASE_URL_DIRECT=postgresql://openpanel:openpanel_local@postgres:5432/openpanel

# ClickHouse
CLICKHOUSE_PASSWORD=clickhouse_local
CLICKHOUSE_URL=http://default:clickhouse_local@clickhouse:8123/openpanel

# Redis
REDIS_URL=redis://redis:6379

# App
# Throwaway values for local dev. Replace in any real deployment.
API_SECRET=local-api-secret-change-in-production-32ch
COOKIE_SECRET=local-cookie-secret-not-for-prod-use

ALLOW_REGISTRATION=true
ALLOW_INVITATION=true
BATCH_SIZE=5000
BATCH_INTERVAL=10000

# URLs
# Server-side, inside the compose network.
DASHBOARD_URL=http://localhost:3000

# Browser-facing, must resolve from the host.
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# Alerting
# Slack incoming webhook for the local Alertmanager receiver.
# Create one at https://api.slack.com/apps under Incoming Webhooks.
# Leave blank to route alerts only to the local webhook-sink.
SLACK_WEBHOOK_URL=
