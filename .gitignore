# Plain secrets and credentials
.env
.env.*
*.pem
*.key
*.crt
secrets/
.secrets
.secrets/
credentials-velero
terraform/environments/staging/credentials-velero

# Keep example/template files in git
!*.example
!*.template
!.env.example

# SealedSecrets (k8s/infrastructure/overlays/*/sealed-secrets/secrets.yaml) DO go
# in git. They're encrypted with the cluster's public key; only the controller
# can decrypt them.

# Node
node_modules/
.pnpm-store/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
terraform.tfvars.json
tfplan
tfplan.bin
tfplan.txt

# Helm chart cache pulled at kustomize render time
k8s/**/charts/

# Local kubeconfig
kubeconfig
*.kubeconfig

# Backups and dumps
*.sql.gz
*.bak
*.backup

# Archives (deliverable zips, Docker tarballs)
*.zip
*.tar
*.tar.gz

# Logs
*.log

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
