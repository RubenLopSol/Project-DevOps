{
  "annotations": { "list": [] },
  "description": "Logs (Loki) on top, traces (Tempo) on the bottom — both scoped to the same namespace variable so you can flip between them without losing context. Loki's derivedField extracts traceID into a clickable Tempo link.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "tags": ["logs", "traces", "loki", "tempo"],
  "title": "Logs & Traces",
  "uid": "logs-traces",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "ds_loki",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "ds_tempo",
        "label": "Tempo",
        "type": "datasource",
        "query": "tempo",
        "current": { "selected": false, "text": "Tempo", "value": "Tempo" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${ds_loki}" },
        "query": "label_values(namespace)",
        "current": { "selected": true, "text": "openpanel", "value": "openpanel" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "logfilter",
        "label": "Log filter (regex)",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      },
      {
        "name": "service",
        "label": "Service (Tempo)",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 100, "title": "Logs", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    {
      "type": "timeseries",
      "id": 1,
      "title": "Log volume by level",
      "description": "Lines per second in the selected namespace, broken down by detected level. A spike of error/warn here is your cue to scroll the live tail below.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${ds_loki}" },
      "targets": [
        { "expr": "sum by (level) (rate({namespace=\"$namespace\"} | logfmt | __error__=\"\" [1m]))", "legendFormat": "{{level}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }, "unit": "logs/s" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "logs",
      "id": 2,
      "title": "Live tail — errors & warnings",
      "description": "Lines containing error/warn (case-insensitive) from the selected namespace. Use the logfilter variable to narrow further (Go regex).",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "${ds_loki}" },
      "targets": [
        { "expr": "{namespace=\"$namespace\"} |~ \"(?i)error|warn\" |~ \"$logfilter\"", "refId": "A" }
      ],
      "options": {
        "dedupStrategy": "exact",
        "enableLogDetails": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    { "type": "row", "id": 101, "title": "Traces", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 } },

    {
      "type": "traces",
      "id": 3,
      "title": "Recent traces",
      "description": "Most recent traces from Tempo for the selected namespace. Set the `service` variable to filter by service.name (TraceQL); leave blank for all services.",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "tempo", "uid": "${ds_tempo}" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.k8s.namespace.name=\"$namespace\" && resource.service.name=~\".*$service.*\" }",
          "limit": 50,
          "refId": "A"
        }
      ]
    },
    {
      "type": "traces",
      "id": 4,
      "title": "Slow traces (> 1s)",
      "description": "Same scope as above but filtered to traces with total duration over 1 second — a quick way to spot the worst offenders without leaving the dashboard.",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "tempo", "uid": "${ds_tempo}" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.k8s.namespace.name=\"$namespace\" && resource.service.name=~\".*$service.*\" && duration > 1s }",
          "limit": 50,
          "refId": "A"
        }
      ]
    }
  ]
}
