{
  "annotations": { "list": [] },
  "description": "OpenPanel application dashboard. Top section is the app workloads (pods + resources). Bottom section is the databases (Postgres, Redis, ClickHouse). Each `up?` stat returns 0/DOWN when there is no scrape series, so a missing target is visible instead of blank.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "tags": ["openpanel", "app", "databases"],
  "title": "OpenPanel",
  "uid": "openpanel",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "ds_prom",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "constant",
        "query": "openpanel",
        "current": { "selected": true, "text": "openpanel", "value": "openpanel" },
        "hide": 2
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 100, "title": "Application — pods & resources", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },

    {
      "type": "stat",
      "id": 1,
      "title": "Pods Running",
      "description": "Pods in phase=Running in the openpanel namespace.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(kube_pod_status_phase{namespace=\"$namespace\",phase=\"Running\"})", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }, "unit": "short" } }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Pods Not Ready",
      "description": "Pods in Pending, Failed or Unknown. Anything non-zero needs investigation.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(kube_pod_status_phase{namespace=\"$namespace\",phase=~\"Pending|Failed|Unknown\"})", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "unit": "short" } }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "API up",
      "description": "Mirrors the APIDown alert (up{job=\"openpanel-api\"} == 0 for 2m).",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "min(up{job=\"openpanel-api\",namespace=\"$namespace\"}) or on() vector(0)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Container restarts (15m)",
      "description": "Container restarts in the openpanel namespace over the last 15 minutes. Steady non-zero means something is crash-looping.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[15m]))", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }, "unit": "short" } }
    },

    {
      "type": "timeseries",
      "id": 5,
      "title": "CPU per pod (cores)",
      "description": "CPU consumed by each pod in the namespace. Uses pod-level cAdvisor series (the kubelet ServiceMonitor in this cluster strips the per-container label, so a `container!=\"\"` filter would return empty).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Memory per pod (% of limit)",
      "description": "Working-set memory as a percentage of the pod's configured limit. Limit comes from kube-state-metrics (`kube_pod_container_resource_limits`) since `container_spec_memory_limit_bytes` is no longer emitted. The HighMemoryUsage alert fires above 90%.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [
        { "expr": "100 * sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\"}) / sum by (pod) (kube_pod_container_resource_limits{namespace=\"$namespace\",resource=\"memory\"} > 0)", "legendFormat": "{{pod}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "percent", "min": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "timeseries",
      "id": 7,
      "title": "API request rate by status (req/s)",
      "description": "RED — Rate. HTTP 2xx vs 5xx on the OpenPanel API. The HighErrorRate alert fires when 5xx / total > 5% for 5m.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum by (status_code) (rate(http_request_duration_seconds_count{namespace=\"$namespace\"}[5m]))", "legendFormat": "{{status_code}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "API latency p50 / p95 / p99 (s)",
      "description": "RED — Duration. The APIHighLatency alert fires when p99 > 2s for 5m.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 5 }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 2 } ] } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "id": 101, "title": "Databases", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 } },

    {
      "type": "stat",
      "id": 9,
      "title": "Postgres up",
      "description": "Mirrors the PostgresDown alert (up{job=\"postgres\"} == 0 for 2m). The job label is the Service name, not the ServiceMonitor name.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "min(up{job=\"postgres\",namespace=\"$namespace\"}) or on() vector(0)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } }
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Redis up",
      "description": "Mirrors the RedisDown alert (up{job=\"redis\"} == 0 for 2m). The job label is the Service name, not the ServiceMonitor name.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "min(up{job=\"redis\",namespace=\"$namespace\"}) or on() vector(0)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "ClickHouse up",
      "description": "Liveness of the ClickHouse pod (no exporter alert yet, so this is the closest signal).",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "max(kube_pod_status_ready{namespace=\"$namespace\",condition=\"true\"} * on(pod) group_left() kube_pod_info{pod=~\"clickhouse.*\"}) or on() vector(0)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "DB PVCs Bound",
      "description": "Number of PVCs in phase=Bound for the openpanel namespace (postgres-data, redis-data, clickhouse-data → expect 3). The `local-path` provisioner used in this cluster does not emit `kubelet_volume_stats_*`, so a fill-percent panel is not available — this is the next-best liveness signal for storage.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(kube_persistentvolumeclaim_status_phase{namespace=\"$namespace\",phase=\"Bound\"}) or on() vector(0)", "refId": "A" } ],
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 3 } ] }, "unit": "short" } }
    },

    {
      "type": "timeseries",
      "id": 15,
      "title": "DB PVC capacity (bytes)",
      "description": "Provisioned capacity of every PVC in the namespace, from kube-state-metrics. The `local-path` provisioner does not emit `kubelet_volume_stats_*`, so used-bytes / fill-percent are unavailable in this cluster — capacity is shown instead so the panel still reflects what storage was requested.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "kube_persistentvolumeclaim_resource_requests_storage_bytes{namespace=\"$namespace\"}", "legendFormat": "{{persistentvolumeclaim}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes", "min": 0 } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "id": 102, "title": "Postgres", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 } },

    {
      "type": "timeseries",
      "id": 13,
      "title": "Postgres connections",
      "description": "Active backends per database (`pg_stat_database_numbackends`). A flat ceiling here usually means `max_connections` is being hit — at that point new connection attempts get rejected.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum by (datname) (pg_stat_database_numbackends{namespace=\"$namespace\"})", "legendFormat": "{{datname}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 16,
      "title": "Postgres transactions / sec",
      "description": "Commit + rollback rate per database (`pg_stat_database_xact_commit` / `_xact_rollback`). A growing rollback share is usually an application bug or a deadlock storm; a sudden drop in commits while the API stays up suggests Postgres is blocked on locks or WAL.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [
        { "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{namespace=\"$namespace\"}[5m]))", "legendFormat": "commit · {{datname}}", "refId": "A" },
        { "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{namespace=\"$namespace\"}[5m]))", "legendFormat": "rollback · {{datname}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 17,
      "title": "Postgres cache hit ratio (%)",
      "description": "Buffer-cache hit ratio: `blks_hit / (blks_hit + blks_read)`. Below ~99% on a steady workload usually means the working set no longer fits in `shared_buffers` and Postgres is going to disk — expect a latency hit on dependent API calls.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "100 * sum(rate(pg_stat_database_blks_hit{namespace=\"$namespace\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{namespace=\"$namespace\"}[5m])) + sum(rate(pg_stat_database_blks_read{namespace=\"$namespace\"}[5m])))", "legendFormat": "hit ratio", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 } ] } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "id": 103, "title": "Redis", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 } },

    {
      "type": "timeseries",
      "id": 14,
      "title": "Redis memory used (bytes)",
      "description": "Resident memory of the Redis instance (`redis_memory_used_bytes`). Compare against `redis_memory_max_bytes` to spot eviction risk — once usage approaches `maxmemory` Redis starts evicting keys per its policy.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "redis_memory_used_bytes{namespace=\"$namespace\"}", "legendFormat": "used", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 18,
      "title": "Redis ops / sec",
      "description": "Commands processed per second (`rate(redis_commands_processed_total[5m])`). For OpenPanel, Redis backs the event queue between API and worker — a drop to zero while the API is still receiving traffic means the worker has stopped consuming.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(rate(redis_commands_processed_total{namespace=\"$namespace\"}[5m]))", "legendFormat": "ops/s", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 19,
      "title": "Redis connected clients",
      "description": "Currently open client connections (`redis_connected_clients`). For OpenPanel, expect API + worker pods × their connection pools. A drop to zero is the clearest signal that no app pod is talking to Redis any more.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "redis_connected_clients{namespace=\"$namespace\"}", "legendFormat": "clients", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short", "min": 0 } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "type": "row", "id": 104, "title": "ClickHouse", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 } },

    {
      "type": "timeseries",
      "id": 20,
      "title": "ClickHouse memory tracking (bytes)",
      "description": "Memory currently tracked by the ClickHouse server (`ClickHouseMetrics_MemoryTracking`). This is the value ClickHouse uses internally for its `max_server_memory_usage` budget — a steady climb means a query or merge is holding memory.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "ClickHouseMetrics_MemoryTracking{namespace=\"$namespace\"}", "legendFormat": "tracked", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "ClickHouse active queries",
      "description": "In-flight queries (`ClickHouseMetrics_Query`). For OpenPanel's read pattern this stays close to zero — sustained values above a handful of queries usually mean the dashboard API is issuing aggregations that aren't completing fast enough.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "ClickHouseMetrics_Query{namespace=\"$namespace\"}", "legendFormat": "queries", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short", "min": 0 } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "ClickHouse inserted rows / sec",
      "description": "Row insert rate (`rate(ClickHouseProfileEvents_InsertedRows[5m])`). This is the throughput of the worker draining the Redis queue into ClickHouse — a drop to zero while Redis ops/sec stays high means the worker→ClickHouse path is broken.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${ds_prom}" },
      "targets": [ { "expr": "sum(rate(ClickHouseProfileEvents_InsertedRows{namespace=\"$namespace\"}[5m]))", "legendFormat": "rows/s", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
